***************************Request to fetch Advisor Information***************************

<request version='1.0'>
    <header>
        <office></office>
        <user></user>
        <password></password>
    </header>
    <search>
        <object>
            <Agent id="Agent.40.735">
                <HireDate/>
                <Status/>
                <Code/>
                <MktManager/>
                <Type/>
