 ***************************Request to fetch Advisor Cont/Appt. Information***************************

  
<request version='1.0'>
    <header>
        <office></office>
        <user></user>
        <password></password>
    </header>
    <search>
        <object>
            <AdvContract>
                <MgrContractId/>
                <CarrierObj>
                    <Name/>
                </CarrierObj>
                <Status/>
                <Agent>
                    <Contact>
                        <LastName/>
                        <FirstLastName/>
                        <SubSource/>
                    </Contact>
                </Agent>
                <ContractNo/>
                <ContractObj>
                    <ContractName/>
                    <ContractType/>
                </ContractObj>
                <EffDate/>
                <ExpDate/>
            </AdvContract>
        </object>
        <condition>
            <expr prop='ContractNo' op='eq'>
                <v>2343333</v>
            </expr>
        </condition>
    </search>
</request>   