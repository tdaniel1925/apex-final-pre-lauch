# =============================================
# Environment Variables - Example File
# Copy this file to .env.local and fill in your values
# =============================================

# Site Configuration
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# OpenAI API (for AI features)
OPENAI_API_KEY="sk-proj-your-openai-api-key-here"

# Resend Email Service
RESEND_API_KEY="re_your-resend-api-key-here"

# Upstash Redis (for rate limiting and caching)
# Get these from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token-here"

# Platform Usage Tracking
# Vercel API Token (for usage tracking)
# Get from: https://vercel.com/account/tokens
VERCEL_API_TOKEN="your-vercel-api-token-here"
VERCEL_TEAM_ID="your-team-id"
VERCEL_PROJECT_ID="your-project-id"

# Supabase Management API Token (for usage tracking)
# Get from: https://app.supabase.com/account/tokens
SUPABASE_ACCESS_TOKEN="your-supabase-management-token-here"

# Cron job secret (to secure cron endpoints)
CRON_SECRET="your-random-secret-here"

# Sentry Error Monitoring (optional but recommended for production)
# Get these from: https://sentry.io/
# NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
# SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# Vercel (automatically set by Vercel, don't need to manually configure)
# VERCEL_OIDC_TOKEN="automatically-set-by-vercel"

# =============================================
# iPipeline SAML SSO Integration
# =============================================
# Enable iPipeline SSO
IPIPELINE_SSO_ENABLED="true"

# SAML Environment (uat or production)
IPIPELINE_ENVIRONMENT="uat"

# SAML Entity ID (your IdP identifier)
IPIPELINE_ENTITY_ID="https://reachtheapex.net/saml/idp"

# SAML Private Key (for signing SAML assertions)
# Generate using: openssl genrsa -out apex-saml.key 2048
# Format: Single line with \n for newlines, or multiline
IPIPELINE_SAML_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----"

# SAML Certificate (public cert matching the private key)
# Generate using: openssl req -new -x509 -key apex-saml.key -out apex-saml.crt -days 3650
# Format: Single line with \n for newlines, or multiline
IPIPELINE_SAML_CERTIFICATE="-----BEGIN CERTIFICATE-----\nYour certificate here\n-----END CERTIFICATE-----"

# =============================================
# Stripe Configuration
# =============================================
# Stripe Secret Key (from Stripe Dashboard)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key-here"

# Stripe Webhook Secret (for general webhooks)
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret-here"

# Stripe Autopilot Product Price IDs
# Create products in Stripe Dashboard, then add price IDs here
# Social Connector ($9/month)
STRIPE_AUTOPILOT_SOCIAL_PRICE_ID="price_social_connector_monthly"

# Lead Autopilot Pro ($79/month with 14-day trial)
STRIPE_AUTOPILOT_PRO_PRICE_ID="price_lead_autopilot_pro_monthly"

# Team Edition ($119/month)
STRIPE_AUTOPILOT_TEAM_PRICE_ID="price_team_edition_monthly"

# Stripe Autopilot Webhook Secret (separate endpoint for autopilot subscriptions)
# Create a separate webhook endpoint in Stripe for /api/webhooks/stripe-autopilot
STRIPE_AUTOPILOT_WEBHOOK_SECRET="whsec_your-autopilot-webhook-secret-here"
