                  "// Generate HMAC signature for webhook",
                  "const webhookSecret = pm.environment.get('webhook_secret') || pm.collectionVariables.get('webhook_secret');",
                  "const requestBody = JSON.parse(pm.request.body.raw);",
                  "const payloadString = JSON.stringify(requestBody);",
                  "const signature = CryptoJS.HmacSHA256(payloadString, webhookSecret).toString(CryptoJS.enc.Hex);",
                  "",
                  "pm.request.headers.upsert({key: 'X-Platform-Signature', value: signature});",
                  "pm.request.headers.upsert({key: 'X-Event-ID', value: 'evt_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9)});",
                  "pm.request.headers.upsert({key: 'X-Event-Timestamp', value: Math.floor(Date.now() / 1000).toString()});"
