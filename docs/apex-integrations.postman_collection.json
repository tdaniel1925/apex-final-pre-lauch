    {
      "name": "Testing & Validation",
      "item": [
        {
          "name": "Verify Signature Generation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// This is a test request to verify your signature generation logic",
                  "const webhookSecret = pm.environment.get('webhook_secret') || pm.collectionVariables.get('webhook_secret');",
                  "",
                  "const testPayload = {",
                  "    \"event\": \"sale.created\",",
                  "    \"amount\": 99.00",
                  "};",
                  "",
                  "const payloadString = JSON.stringify(testPayload);",
                  "const expectedSignature = CryptoJS.HmacSHA256(payloadString, webhookSecret).toString(CryptoJS.enc.Hex);",
                  "",
                  "console.log('Test Payload:', payloadString);",
                  "console.log('Webhook Secret:', webhookSecret.substring(0, 10) + '...');",
                  "console.log('Generated Signature:', expectedSignature);",
                  "",
