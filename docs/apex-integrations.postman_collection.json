    {
      "name": "Webhook API (Send to Apex)",
      "item": [
        {
          "name": "Send Sale Created Webhook",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate HMAC signature for webhook",
                  "const webhookSecret = pm.environment.get('webhook_secret') || pm.collectionVariables.get('webhook_secret');",
                  "",
                  "// Get the request body",
                  "const requestBody = JSON.parse(pm.request.body.raw);",
                  "",
                  "// Generate signature",
                  "const payloadString = JSON.stringify(requestBody);",
                  "const signature = CryptoJS.HmacSHA256(payloadString, webhookSecret).toString(CryptoJS.enc.Hex);",
                  "",
                  "// Set headers",
                  "pm.request.headers.add({",
                  "    key: 'X-Platform-Signature',",
                  "    value: signature",
                  "});",
                  "",
                  "pm.request.headers.add({",
                  "    key: 'X-Event-ID',",
                  "    value: 'evt_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9)",
                  "});",
                  "",
                  "pm.request.headers.add({",
                  "    key: 'X-Event-Timestamp',",
                  "    value: Math.floor(Date.now() / 1000).toString()",
                  "});",
                  "",
                  "console.log('Generated signature:', signature);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Webhook processed successfully\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.event_id).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"sale.created\",\n  \"event_id\": \"evt_7f8g9h0i1j2k3l4m\",\n  \"timestamp\": \"{{$isoTimestamp}}\",\n  \"platform\": {\n    \"name\": \"{{platform_name}}\",\n    \"version\": \"1.0.0\"\n  },\n  \"seller\": {\n    \"user_id\": \"ext_user_7a9b3c4d5e6f\",\n    \"apex_distributor_id\": \"{{test_distributor_id}}\",\n    \"apex_member_id\": \"M123456\",\n    \"email\": \"john.doe@example.com\",\n    \"name\": \"John Doe\"\n  },\n  \"order\": {\n    \"order_id\": \"ord_8k9l0m1n2o3p\",\n    \"order_number\": \"ORD-2026-03-1234\",\n    \"status\": \"completed\"\n  },\n  \"product\": {\n    \"product_id\": \"prod_5e6f7g8h9i0j\",\n    \"product_name\": \"Business Starter Pack\",\n    \"product_sku\": \"BSP-001\",\n    \"product_category\": \"digital_products\"\n  },\n  \"transaction\": {\n    \"amount\": 99.00,\n    \"currency\": \"USD\",\n    \"payment_method\": \"credit_card\",\n    \"transaction_id\": \"txn_1a2b3c4d5e6f\"\n  },\n  \"customer\": {\n    \"customer_id\": \"cust_9j8k7l6m5n4o\",\n    \"email\": \"customer@example.com\",\n    \"name\": \"Jane Smith\",\n    \"phone\": \"+1-555-987-6543\"\n  },\n  \"metadata\": {\n    \"commission_eligible\": true,\n    \"sale_type\": \"direct\",\n    \"channel\": \"web\"\n  }\n}",
              "options": {
