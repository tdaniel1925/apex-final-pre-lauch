    {
      "parameters": {
        "jsCode": "const webhook = $('Webhook').item.json.body;\nconst raw = $input.first().json;\nconst dist = Array.isArray(raw) ? raw[0] : raw;\n\nif (!dist) throw new Error('Distributor not found');\n\nconst sponsor = Array.isArray(dist.sponsor) && dist.sponsor.length > 0 ? dist.sponsor[0] : dist.sponsor;\nconst sponsorName = sponsor ? `${sponsor.first_name} ${sponsor.last_name}` : 'Apex Vision';\n\nreturn [{\n  json: {\n    distributorId: webhook.distributorId,\n    firstName: webhook.firstName,\n    lastName: webhook.lastName,\n    email: webhook.email,\n    phone: dist.phone || '',\n    slug: dist.slug,\n    sponsorName: sponsorName,\n    replicatedSiteUrl: `https://reachtheapex.net/${dist.slug}`\n  }\n}];"
      },
