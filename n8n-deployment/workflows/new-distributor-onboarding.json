      "id": "6",
      "name": "Provision AI Phone",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 380],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\n\n// Facebook - Friendly, emoji-rich, longer format\nconst facebook = `🎉 Welcome ${d.firstName} ${d.lastName} to Apex Affinity Group! 🎉\n\nWe're excited to have you on the team under the sponsorship of ${d.sponsorName}! ${d.firstName} is ready to build a successful insurance business and help others reach financial freedom.\n\nLet's reach the apex together! 🚀\n\nLearn more: ${d.replicatedSiteUrl}\n\n#ApexAffinity #NewTeamMember #InsuranceBusiness #FinancialFreedom #NetworkMarketing`;\n\n// LinkedIn - Professional, detailed, business-focused\nconst linkedIn = `We're thrilled to welcome ${d.firstName} ${d.lastName} to Apex Affinity Group!\n\n${d.firstName} joins us under the sponsorship of ${d.sponsorName} and is ready to embark on an exciting journey in the insurance and financial services industry.\n\nAt Apex Affinity Group, we're committed to:\n✅ Providing comprehensive training and support\n✅ Building a collaborative team environment\n✅ Helping our members achieve financial independence\n✅ Delivering exceptional value to our clients\n\nWelcome to the team, ${d.firstName}! We're excited to support your success.\n\nReplicated Site: ${d.replicatedSiteUrl}\n\n#ApexAffinity #Insurance #FinancialServices #TeamGrowth #Welcome`;\n\n// X (Twitter) - Short, hashtags, 280 char limit\nconst x = `🎉 Welcome ${d.firstName} ${d.lastName} to @ApexAffinity!\n\nSponsored by ${d.sponsorName}\n\nReady to reach the apex! 🚀\n\n${d.replicatedSiteUrl}\n\n#ApexAffinity #Insurance #NewMember #FinancialFreedom`;\n\n// Instagram - Visual, emoji-heavy, hashtag-rich\nconst instagram = `🎉✨ WELCOME TO THE TEAM! ✨🎉\n\n${d.firstName} ${d.lastName} just joined Apex Affinity Group under ${d.sponsorName}! 🙌\n\nWe're SO excited to have you on this journey! 💼🚀\n\nReady to build something amazing? Let's go! 💪\n\n👉 ${d.replicatedSiteUrl}\n\n#ApexAffinity #WelcomeToTheTeam #NewMember #Insurance #FinancialFreedom #NetworkMarketing #Success #DreamBig #TeamWork #BusinessOpportunity #entrepreneur #sidehustle #financialindependence`;\n\n// TikTok - Casual, trending, short, hashtag-heavy\nconst tiktok = `Welcome to Apex! 🎉\n\n${d.firstName} ${d.lastName} just joined the team! 🙌\n\nSponsored by: ${d.sponsorName}\n\nReady to level up? 🚀💰\n\nLink in bio! 👆\n\n#ApexAffinity #NewMember #Insurance #FinancialFreedom #SideHustle #PassiveIncome #BusinessOpportunity #MLM #NetworkMarketing #FinTok #MoneyTok #entrepreneur #success #teamwork #welcome`;\n\nreturn [{\n  json: {\n    newMember: `${d.firstName} ${d.lastName}`,\n    sponsor: d.sponsorName,\n    siteUrl: d.replicatedSiteUrl,\n    facebook: facebook,\n    linkedIn: linkedIn,\n    x: x,\n    instagram: instagram,\n    tiktok: tiktok\n  }\n}];"
      },
