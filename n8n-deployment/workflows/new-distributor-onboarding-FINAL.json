      "id": "get-distributor-details",
      "name": "Get Distributor Details",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [700, 300],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Get data from webhook\nconst webhookData = $('Webhook Trigger').item.json.body;\n\n// Get distributor data from Supabase\nconst distributorArray = $('Get Distributor Details').item.json;\nconst distributor = Array.isArray(distributorArray) ? distributorArray[0] : distributorArray;\n\nif (!distributor) {\n  throw new Error('Distributor data not found');\n}\n\n// Handle sponsor as array or object\nconst sponsor = Array.isArray(distributor.sponsor) && distributor.sponsor.length > 0 \n  ? distributor.sponsor[0] \n  : distributor.sponsor;\n\nconst sponsorName = sponsor \n  ? `${sponsor.first_name} ${sponsor.last_name}`\n  : 'Apex Vision';\n\nreturn [{\n  json: {\n    distributorId: webhookData.distributorId,\n    firstName: webhookData.firstName,\n    lastName: webhookData.lastName,\n    email: webhookData.email,\n    phone: distributor.phone || '',\n    slug: distributor.slug,\n    sponsorName: sponsorName,\n    replicatedSiteUrl: `https://reachtheapex.net/${distributor.slug}`\n  }\n}];"
      },
