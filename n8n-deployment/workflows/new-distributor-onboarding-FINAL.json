      "id": "provision-ai-phone",
      "name": "Provision AI Phone",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1140, 400],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Get prepared data\nconst data = $('Prepare Data').item.json;\n\nconst facebookPost = `🎉 Welcome ${data.firstName} ${data.lastName} to Apex Affinity Group! Excited to have you on the team under ${data.sponsorName}. Let's reach the apex together! 🚀`;\n\nconst twitterPost = `Welcome ${data.firstName} ${data.lastName} to @ApexAffinity! 🎉 Sponsored by ${data.sponsorName}. #ApexAffinity #NetworkMarketing #Insurance`;\n\nconst linkedInPost = `We're thrilled to welcome ${data.firstName} ${data.lastName} to Apex Affinity Group! ${data.firstName} joins us under the sponsorship of ${data.sponsorName}. We're excited to support your journey in building a successful insurance business. Welcome to the team!\\n\\nReplicated Site: ${data.replicatedSiteUrl}`;\n\nreturn [{\n  json: {\n    newMemberName: `${data.firstName} ${data.lastName}`,\n    sponsorName: data.sponsorName,\n    replicatedSiteUrl: data.replicatedSiteUrl,\n    facebook: facebookPost,\n    twitter: twitterPost,\n    linkedIn: linkedInPost\n  }\n}];"
      },
